      </column>
      <column caption='Max_Drawndown_Recommendation' datatype='string' name='[Calculation_1467329109288509440]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Max Drawdown] &gt;= -0.10 &#13;&#10;THEN &quot;Low Risk&quot;&#13;&#10;&#13;&#10;ELSEIF [Max Drawdown] &gt;= -0.25 &#13;&#10;THEN &quot;Moderate Risk&quot;&#13;&#10;&#13;&#10;ELSEIF [Max Drawdown] &gt;= -0.50 &#13;&#10;THEN &quot;High Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Investment_Recommendation_NIFTYBEES' datatype='string' name='[Calculation_1512365103159828480]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sharpe] &gt; 0.5 &#13;&#10;AND [Volatility] &lt; 0.02 &#13;&#10;AND [Volume] &gt; 100000 &#13;&#10;THEN &quot;Recommended&quot;&#13;&#10;&#13;&#10;ELSEIF [Sharpe] &gt; 0.3 &#13;&#10;THEN &quot;Consider&quot;&#13;&#10;&#13;&#10;ELSE &quot;Avoid&quot;&#13;&#10;END' />
      </column>
      <column caption='Investment_Recommendation_ITBEES' datatype='string' name='[Calculation_1512365103160324097]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sharpe (ITBEES.NS1)] &gt; 0.5 &#13;&#10;AND [Volatility (ITBEES.NS1)]&lt; 0.02 &#13;&#10;AND [Volume (ITBEES.NS1)] &gt; 100000 &#13;&#10;THEN &quot;Recommended&quot;&#13;&#10;&#13;&#10;ELSEIF [Sharpe (ITBEES.NS1)] &gt; 0.3 &#13;&#10;THEN &quot;Consider&quot;&#13;&#10;&#13;&#10;ELSE &quot;Avoid&quot;&#13;&#10;END' />
      </column>
      <column caption='Hit_Ratio_Niftybees' datatype='real' name='[Calculation_1512365103172964355]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [NIFTYBEES.NS (Returns)] &gt; 0 THEN 1 ELSE 0 END&#13;&#10;) / COUNT([NIFTYBEES.NS (Returns)])' />
      </column>
      <column caption='Hit_Ratio_Itbees' datatype='real' name='[Calculation_1512365103173324804]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [ITBEES.NS] &gt; 0 THEN 1 ELSE 0 END&#13;&#10;) / COUNT([ITBEES.NS])' />
      </column>
      <column caption='Liquidity_Score_Niftybees' datatype='string' name='[Calculation_1512365103175704581]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Volume] &gt; 100000 THEN &quot;High Liquidity&quot;&#13;&#10;ELSE &quot;Low Liquidity&quot;&#13;&#10;END' />
      </column>
      <column caption='Liquidity_Score_ITBEES' datatype='string' name='[Calculation_1512365103176269830]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Volume (ITBEES.NS1)]) &gt; WINDOW_AVG(SUM([Volume (ITBEES.NS1)])) THEN &quot;High Liquidity&quot;&#13;&#10;ELSE &quot;Low Liquidity&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Risk_Score_Niftybees' datatype='string' name='[Calculation_1512365103177445383]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Volatility] &lt; 0.01 THEN &quot;Low Risk&quot;&#13;&#10;ELSEIF [Volatility] &lt; 0.02 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk_Score_ITBEES' datatype='string' name='[Calculation_1512365103177928712]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Volatility (ITBEES.NS1)] &lt; 0.01 THEN &quot;Low Risk&quot;&#13;&#10;ELSEIF [Volatility (ITBEES.NS1)] &lt; 0.02 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
